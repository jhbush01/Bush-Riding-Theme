{
  "version": 8,
  "name": "Bush Riding — Documentary Light (OpenFreeMap)",
  "metadata": {
    "comment": "Brand-recoloured basemap on the OpenMapTiles schema, served by OpenFreeMap (free, no key, whole planet) — the brief's sanctioned day-one source. Almond-cream land, sage/olive greens, muted water. Bush-lemon is reserved for the active pin/line in map.js and is NOT used here. For the self-hosted Protomaps PMTiles path, see bush-protomaps.json."
  },
  "glyphs": "https://tiles.openfreemap.org/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#E9E2D0" }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["in", "class", "wood", "forest"],
      "paint": { "fill-color": "#AEB995", "fill-opacity": 0.55 }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["in", "class", "grass", "scrub", "heath", "farmland"],
      "paint": { "fill-color": "#DAE0C2", "fill-opacity": 0.5 }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": { "fill-color": "#CBD4B3", "fill-opacity": 0.55 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": { "fill-color": "#A7BFBD" }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#A7BFBD",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 1.6]
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "minor", "service", "track", "path"],
      "minzoom": 12,
      "paint": {
        "line-color": "#F4EFE2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.4, 16, 2]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "secondary", "tertiary"],
      "paint": {
        "line-color": "#FBF8F0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 16, 4]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "primary", "trunk"],
      "paint": {
        "line-color": "#F6EFD9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.6, 16, 5]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "motorway"],
      "paint": {
        "line-color": "#EFE6C9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.8, 16, 6]
      }
    },
    {
      "id": "boundary-country",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["<=", "admin_level", 2],
      "paint": {
        "line-color": "#B7AE97",
        "line-dasharray": [2, 1.5],
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.6, 10, 1.4]
      }
    },
    {
      "id": "place-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["in", "class", "city", "town", "village"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 10, 12, 14],
        "text-max-width": 7,
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#5A5346",
        "text-halo-color": "#EDE7D7",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "place-state",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "state"],
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 8, 13],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#8A8068",
        "text-halo-color": "#EDE7D7",
        "text-halo-width": 1.2
      }
    }
  ]
}
