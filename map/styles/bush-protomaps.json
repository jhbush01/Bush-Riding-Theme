{
  "version": 8,
  "name": "Bush Riding — Documentary Light",
  "metadata": {
    "comment": "Recoloured Protomaps `light` flavor (CC0 base) to the Bush Riding palette. Almond-cream land, sage/olive greens, muted water. Bush-lemon is reserved for the active pin/line in map.js and is intentionally NOT used in the basemap.",
    "tile-schema": "protomaps basemap v4"
  },
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf",
  "sources": {
    "protomaps": {
      "type": "vector",
      "attribution": "<a href=\"https://protomaps.com\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap</a>",
      "url": "pmtiles://__TILES_URL__"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#E9E2D0" }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "paint": { "fill-color": "#E9E2D0" }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "park", "national_park", "nature_reserve", "protected_area", "forest", "wood", "recreation_ground", "grass", "meadow"],
      "paint": { "fill-color": "#CBD4B3", "fill-opacity": 0.7 }
    },
    {
      "id": "landcover-forest",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "filter": ["in", "kind", "forest", "tree", "wood", "scrub"],
      "paint": { "fill-color": "#AEB995", "fill-opacity": 0.55 }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "filter": ["in", "kind", "grassland", "grass", "farmland", "crop"],
      "paint": { "fill-color": "#DAE0C2", "fill-opacity": 0.5 }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "paint": { "fill-color": "#A7BFBD" }
    },
    {
      "id": "water-stream",
      "type": "line",
      "source": "protomaps",
      "source-layer": "physical_line",
      "filter": ["in", "kind", "river", "stream", "canal"],
      "paint": {
        "line-color": "#A7BFBD",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.4, 14, 1.4]
      }
    },
    {
      "id": "roads-other",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "minor_road", "path", "track"],
      "minzoom": 11,
      "paint": {
        "line-color": "#F4EFE2",
        "line-width": ["interpolate", ["linear"], ["zoom"], 11, 0.4, 16, 2]
      }
    },
    {
      "id": "roads-medium",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "medium_road"],
      "paint": {
        "line-color": "#FBF8F0",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 16, 4]
      }
    },
    {
      "id": "roads-major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "major_road", "highway"],
      "paint": {
        "line-color": "#F6EFD9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 0.6, 16, 6]
      }
    },
    {
      "id": "boundaries",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": ["<=", "kind_detail", 4],
      "paint": {
        "line-color": "#B7AE97",
        "line-dasharray": [2, 1.5],
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.5, 10, 1.2]
      }
    },
    {
      "id": "places-locality",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "kind", "locality", "city", "town", "village"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 10, 12, 14],
        "text-max-width": 7,
        "text-letter-spacing": 0.05
      },
      "paint": {
        "text-color": "#5A5346",
        "text-halo-color": "#EDE7D7",
        "text-halo-width": 1.3
      }
    },
    {
      "id": "places-region",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["in", "kind", "region", "country"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 10, 8, 13],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.12,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#8A8068",
        "text-halo-color": "#EDE7D7",
        "text-halo-width": 1.2
      }
    }
  ]
}
