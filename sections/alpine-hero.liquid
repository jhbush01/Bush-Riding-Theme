{%- comment -%}
  Bush Riding hero — full-bleed photograph/video filling the viewport under
  the floating nav. Two chip buttons sit centred just below the nav: one
  linking to the featured product (Bush Riding Shorts), one to the map
  (BUSH MAP™ → map.bushriding.cc).
{%- endcomment -%}

<section class="alp alp-hero">
  <div class="alp-hero__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 3200 | image_tag: loading: 'eager', alt: section.settings.image.alt | default: '' }}
    {%- elsif section.settings.video_url != blank -%}
      <video autoplay muted loop playsinline aria-hidden="true"
        {% if section.settings.poster != blank %}poster="{{ section.settings.poster | image_url: width: 1800 }}"{% endif %}>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- else -%}
      <img src="{{ 'alpine-ph-hero.svg' | asset_url }}" alt="" loading="eager"
        data-asset-note="Full-bleed hero: hiker on mossy terrain against a pale blown-out sky, as in frame f_01">
    {%- endif -%}
  </div>

  <div class="alp-hero__cta">
    {%- if section.settings.shorts_product != blank -%}
      <a class="alp-chip" href="{{ section.settings.shorts_product.url }}">{{ section.settings.shorts_label | default: section.settings.shorts_product.title | escape }} <span class="alp-glyph">✦</span></a>
    {%- elsif section.settings.shorts_label != blank -%}
      <a class="alp-chip" href="{{ section.settings.shorts_fallback_url | default: '#' }}">{{ section.settings.shorts_label | escape }} <span class="alp-glyph">✦</span></a>
    {%- endif -%}
    {%- if section.settings.map_label != blank -%}
      <a class="alp-chip" href="{{ section.settings.map_url | default: 'https://map.bushriding.cc' }}">{{ section.settings.map_label | escape }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Bush Riding hero",
  "tag": "div",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Takes priority over the video."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video (MP4 URL)"
    },
    {
      "type": "image_picker",
      "id": "poster",
      "label": "Video poster image"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "product",
      "id": "shorts_product",
      "label": "Featured product"
    },
    {
      "type": "text",
      "id": "shorts_label",
      "label": "Product button label",
      "default": "Bush Riding Shorts"
    },
    {
      "type": "url",
      "id": "shorts_fallback_url",
      "label": "Product button URL (if no product picked)"
    },
    {
      "type": "text",
      "id": "map_label",
      "label": "Map button label",
      "default": "BUSH MAP™"
    },
    {
      "type": "url",
      "id": "map_url",
      "label": "Map button URL",
      "info": "Defaults to https://map.bushriding.cc when blank."
    }
  ],
  "presets": [
    { "name": "Bush Riding hero" }
  ]
}
{% endschema %}
