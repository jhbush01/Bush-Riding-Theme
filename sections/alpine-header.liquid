{%- comment -%}
  Bush Riding header — wordmark + clock, two visible items (Shop, BUSH MAP™),
  and a hamburger in the corner. The hamburger opens a full-screen menu that
  expands from the corner (wiping the page away), split into quarters by thin
  white lines: Shop (image), a video panel, an account / sign-in panel, and a
  link to Bush Map.
{%- endcomment -%}

{%- liquid
  assign shop_url = section.settings.shop_url | default: routes.all_products_collection_url
  assign map_url = section.settings.map_url | default: 'https://map.bushriding.cc'
  assign shop_label = section.settings.shop_label | default: 'Shop'
  assign map_label = section.settings.map_label | default: 'BUSH MAP™'
-%}

<header class="alp alp-head" data-alp-header>
  <div class="alp-head__group">
    <a class="alp-nav-link alp-nav-link--wordmark" href="{{ routes.root_url }}">{{ section.settings.wordmark | default: shop.name | escape }}</a>
    <span
      class="alp-nav-link alp-nav-link--clock"
      data-alp-clock="{{ section.settings.clock_timezone | default: 'Australia/Brisbane' | escape }}"
      data-alp-clock-label="{{ section.settings.clock_label | default: 'AEST' | escape }}"
    ></span>
  </div>

  <nav class="alp-head__nav" aria-label="Primary">
    <a class="alp-nav-link" href="{{ shop_url }}">{{ shop_label | escape }}</a>
    <a class="alp-nav-link" href="{{ map_url }}">{{ map_label | escape }}</a>
  </nav>

  <div class="alp-head__group">
    <button class="alp-nav-link alp-nav-link--menu" type="button" data-alp-menu-open aria-expanded="false" aria-controls="alp-menu-overlay" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="alp alp-menu" id="alp-menu-overlay" data-alp-menu aria-hidden="true">
  <button class="alp-menu__close" type="button" data-alp-menu-close aria-label="Close menu">
    <span></span><span></span>
  </button>

  <div class="alp-menu__grid">
    {%- comment -%} Top-left: Shop, image background {%- endcomment -%}
    <a class="alp-menu__q alp-menu__q--shop" href="{{ shop_url }}" data-alp-menu-link>
      {%- if section.settings.menu_shop_image != blank -%}
        <span class="alp-menu__media" style="background-image:url('{{ section.settings.menu_shop_image | image_url: width: 1400 }}')"></span>
      {%- else -%}
        <span class="alp-menu__media alp-menu__media--ph"></span>
      {%- endif -%}
      <span class="alp-menu__label">{{ shop_label | escape }}</span>
    </a>

    {%- comment -%} Top-right: video panel {%- endcomment -%}
    <a class="alp-menu__q alp-menu__q--video" href="{{ section.settings.menu_video_url_link | default: shop_url }}" data-alp-menu-link>
      {%- if section.settings.menu_video_url != blank -%}
        <video class="alp-menu__media" autoplay muted loop playsinline aria-hidden="true"
          {% if section.settings.menu_video_poster != blank %}poster="{{ section.settings.menu_video_poster | image_url: width: 1400 }}"{% endif %}>
          <source src="{{ section.settings.menu_video_url }}" type="video/mp4">
        </video>
      {%- else -%}
        <span class="alp-menu__media alp-menu__media--ph"></span>
      {%- endif -%}
      {%- if section.settings.menu_video_label != blank -%}
        <span class="alp-menu__label">{{ section.settings.menu_video_label | escape }}</span>
      {%- endif -%}
    </a>

    {%- comment -%} Bottom-left: account / sign-in {%- endcomment -%}
    {%- if customer -%}
      <a class="alp-menu__q alp-menu__q--account" href="{{ routes.account_url }}" data-alp-menu-link>
        <span class="alp-menu__label">{{ customer.first_name | escape }} {{ customer.last_name | escape }}</span>
        <span class="alp-menu__sub">My account</span>
      </a>
    {%- else -%}
      <a class="alp-menu__q alp-menu__q--account" href="{{ routes.account_login_url }}" data-alp-menu-link>
        <span class="alp-menu__label">Sign in</span>
        <span class="alp-menu__sub">{{ section.settings.signin_sub | default: 'Shop the community' | escape }}</span>
      </a>
    {%- endif -%}

    {%- comment -%} Bottom-right: Bush Map {%- endcomment -%}
    <a class="alp-menu__q alp-menu__q--map" href="{{ map_url }}" data-alp-menu-link>
      {%- if section.settings.menu_map_image != blank -%}
        <span class="alp-menu__media" style="background-image:url('{{ section.settings.menu_map_image | image_url: width: 1400 }}')"></span>
      {%- endif -%}
      <span class="alp-menu__label">{{ map_label | escape }}</span>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Bush Riding header",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark",
      "default": "Bush Riding™",
      "info": "Leave blank to use the store name."
    },
    {
      "type": "text",
      "id": "clock_timezone",
      "label": "Clock time zone (IANA id)",
      "default": "Australia/Brisbane"
    },
    {
      "type": "text",
      "id": "clock_label",
      "label": "Clock zone label",
      "default": "AEST"
    },
    {
      "type": "header",
      "content": "Visible items"
    },
    { "type": "text", "id": "shop_label", "label": "Shop label", "default": "Shop" },
    { "type": "url", "id": "shop_url", "label": "Shop URL", "info": "Defaults to the all-products catalog." },
    { "type": "text", "id": "map_label", "label": "Map label", "default": "BUSH MAP™" },
    { "type": "url", "id": "map_url", "label": "Map URL", "info": "Defaults to https://map.bushriding.cc." },
    {
      "type": "header",
      "content": "Menu — quarters"
    },
    { "type": "image_picker", "id": "menu_shop_image", "label": "Shop panel image (top left)" },
    { "type": "url", "id": "menu_video_url", "label": "Video panel MP4 URL (top right)" },
    { "type": "image_picker", "id": "menu_video_poster", "label": "Video poster" },
    { "type": "text", "id": "menu_video_label", "label": "Video panel label" },
    { "type": "url", "id": "menu_video_url_link", "label": "Video panel link" },
    { "type": "text", "id": "signin_sub", "label": "Sign-in subtitle", "default": "Shop the community" },
    { "type": "image_picker", "id": "menu_map_image", "label": "Map panel image (bottom right)" }
  ]
}
{% endschema %}
