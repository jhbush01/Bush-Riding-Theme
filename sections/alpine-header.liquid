{%- comment -%}
  ALP1NE chip header — fixed bar of white chips over the page (frames f_01–f_16):
  wordmark + live clock on the left, nav chips centre, social/utility right.
  Collapses to a Menu chip on mobile, opening the olive overlay.
{%- endcomment -%}

<header class="alp alp-head" data-alp-header>
  <div class="alp-head__group">
    <a class="alp-nav-link alp-nav-link--wordmark" href="{{ routes.root_url }}">{{ section.settings.wordmark | default: shop.name | escape }}</a>
  </div>

  <nav class="alp-head__nav" aria-label="Primary">
    {%- for link in section.settings.menu.links -%}
      <a class="alp-nav-link" href="{{ link.url }}">{{ link.title | escape }}</a>
    {%- endfor -%}
    {%- if section.settings.map_label != blank -%}
      {%- assign alp_map_url = section.settings.map_url | default: 'https://map.bushriding.cc' -%}
      <a class="alp-nav-link" href="{{ alp_map_url }}">{{ section.settings.map_label | escape }}</a>
    {%- endif -%}
  </nav>

  <div class="alp-head__group">
    {%- if section.settings.social_instagram != blank -%}
      <a class="alp-nav-link alp-head__social" href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener">Instagram</a>
    {%- endif -%}
    {%- if section.settings.social_press_url != blank -%}
      <a class="alp-nav-link alp-head__social" href="{{ section.settings.social_press_url }}">{{ section.settings.social_press_label | default: 'Press' | escape }}</a>
    {%- endif -%}
    <a class="alp-nav-link" href="{{ routes.cart_url }}" id="alp-cart-chip">
      Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
    </a>
    <button class="alp-nav-link alp-nav-link--menu" type="button" data-alp-menu-open aria-expanded="false" aria-controls="alp-menu-overlay">Menu</button>

    {%- comment -%} Gravel tyre clock — pink knobby tread, tan sidewall,
        black rim; the hands tick live in the configured time zone. {%- endcomment -%}
    <svg class="alp-tyre" viewBox="0 0 100 100" role="img" aria-label="Clock"
      data-alp-tyre="{{ section.settings.clock_timezone | default: 'America/Los_Angeles' | escape }}">
      <circle cx="50" cy="50" r="49" fill="#E9868C"/>
      <circle cx="50" cy="50" r="49" fill="none" stroke="#D97880" stroke-width="1.5"/>
      <circle cx="50" cy="50" r="45" fill="none" stroke="#C96A72" stroke-width="7" stroke-dasharray="4 3"/>
      <circle cx="50" cy="50" r="39" fill="#C69C6D"/>
      <defs>
        <path id="AlpTyreTextPath" d="M50,50 m-33.5,0 a33.5,33.5 0 1,1 67,0 a33.5,33.5 0 1,1 -67,0"/>
      </defs>
      <text font-family="Inter, sans-serif" font-size="4.7" font-weight="700" letter-spacing="1.1" fill="#FFF8E7">
        <textPath href="#AlpTyreTextPath">BUSH RIDING ✦ TLR 40C ✦ MADE FOR GRAVEL ✦</textPath>
      </text>
      <circle cx="50" cy="50" r="26" fill="#141414"/>
      <circle cx="50" cy="50" r="22" fill="none" stroke="#2B2B2B" stroke-width="1.4" stroke-dasharray="0.1 6.7" stroke-linecap="round"/>
      <g data-alp-hand="hour"><rect x="48.75" y="34" width="2.5" height="17" rx="1.2" fill="#F2F0E8"/></g>
      <g data-alp-hand="minute"><rect x="49.1" y="28.5" width="1.8" height="22.5" rx="0.9" fill="#F2F0E8"/></g>
      <g data-alp-hand="second"><rect x="49.65" y="26" width="0.7" height="26" fill="#E9868C"/></g>
      <circle cx="50" cy="50" r="2.6" fill="#F2F0E8"/>
      <circle cx="50" cy="50" r="1.1" fill="#E9868C"/>
    </svg>
  </div>
</header>

<div class="alp alp-menu" id="alp-menu-overlay" data-alp-menu hidden>
  <button class="alp-chip alp-menu__close" type="button" data-alp-menu-close>Close</button>
  <nav aria-label="Overlay">
    <ul role="list">
      {%- for link in section.settings.menu.links -%}
        <li><a href="{{ link.url }}" data-alp-menu-link>{{ link.title | escape }}</a></li>
      {%- endfor -%}
      {%- if section.settings.map_label != blank -%}
        {%- assign alp_map_url_menu = section.settings.map_url | default: 'https://map.bushriding.cc' -%}
        <li><a href="{{ alp_map_url_menu }}" data-alp-menu-link>{{ section.settings.map_label | escape }}</a></li>
      {%- endif -%}
      <li><a href="{{ routes.cart_url }}" data-alp-menu-link>Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</a></li>
      {%- if section.settings.social_instagram != blank -%}
        <li><a href="{{ section.settings.social_instagram }}" data-alp-menu-link target="_blank" rel="noopener">Instagram</a></li>
      {%- endif -%}
    </ul>
  </nav>
</div>

{% schema %}
{
  "name": "ALP1NE header",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark",
      "default": "ALP1NE™",
      "info": "Leave blank to use the store name."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "clock_timezone",
      "label": "Clock time zone (IANA id)",
      "default": "America/Los_Angeles"
    },
    {
      "type": "text",
      "id": "clock_label",
      "label": "Clock zone label",
      "default": "PST",
      "info": "Unused since the clock became the tyre; kept for compatibility."
    },
    {
      "type": "text",
      "id": "map_label",
      "label": "Map link label",
      "default": "Map",
      "info": "Leave blank to hide the Map link."
    },
    {
      "type": "url",
      "id": "map_url",
      "label": "Map link URL",
      "info": "Defaults to https://map.bushriding.cc when blank."
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_press_url",
      "label": "Press link URL"
    },
    {
      "type": "text",
      "id": "social_press_label",
      "label": "Press link label",
      "default": "Press"
    }
  ]
}
{% endschema %}
