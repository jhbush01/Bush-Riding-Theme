{%- comment -%}
  ALP1NE chip header — fixed bar of white chips over the page (frames f_01–f_16):
  wordmark + live clock on the left, nav chips centre, social/utility right.
  Collapses to a Menu chip on mobile, opening the olive overlay.
{%- endcomment -%}

<header class="alp alp-head" data-alp-header>
  <div class="alp-head__group">
    <a class="alp-chip alp-chip--wordmark" href="{{ routes.root_url }}">{{ section.settings.wordmark | default: shop.name | escape }}</a>
    <span
      class="alp-chip alp-chip--clock"
      data-alp-clock="{{ section.settings.clock_timezone | escape }}"
      data-alp-clock-label="{{ section.settings.clock_label | escape }}"
    ></span>
  </div>

  <nav class="alp-head__nav" aria-label="Primary">
    {%- for link in section.settings.menu.links -%}
      <a class="alp-chip" href="{{ link.url }}">{{ link.title | escape }}</a>
    {%- endfor -%}
  </nav>

  <div class="alp-head__group">
    {%- if section.settings.social_instagram != blank -%}
      <a class="alp-chip alp-head__social" href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener">Instagram</a>
    {%- endif -%}
    {%- if section.settings.social_press_url != blank -%}
      <a class="alp-chip alp-head__social" href="{{ section.settings.social_press_url }}">{{ section.settings.social_press_label | default: 'Press' | escape }}</a>
    {%- endif -%}
    <a class="alp-chip" href="{{ routes.cart_url }}" id="alp-cart-chip">
      Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}
    </a>
    <button class="alp-chip alp-chip--menu" type="button" data-alp-menu-open aria-expanded="false" aria-controls="alp-menu-overlay">Menu</button>
  </div>
</header>

<div class="alp alp-menu" id="alp-menu-overlay" data-alp-menu hidden>
  <button class="alp-chip alp-menu__close" type="button" data-alp-menu-close>Close</button>
  <nav aria-label="Overlay">
    <ul role="list">
      {%- for link in section.settings.menu.links -%}
        <li><a href="{{ link.url }}" data-alp-menu-link>{{ link.title | escape }}</a></li>
      {%- endfor -%}
      <li><a href="{{ routes.cart_url }}" data-alp-menu-link>Cart{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}</a></li>
      {%- if section.settings.social_instagram != blank -%}
        <li><a href="{{ section.settings.social_instagram }}" data-alp-menu-link target="_blank" rel="noopener">Instagram</a></li>
      {%- endif -%}
    </ul>
  </nav>
</div>

{% schema %}
{
  "name": "ALP1NE header",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark",
      "default": "ALP1NE™",
      "info": "Leave blank to use the store name."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "clock_timezone",
      "label": "Clock time zone (IANA id)",
      "default": "America/Los_Angeles"
    },
    {
      "type": "text",
      "id": "clock_label",
      "label": "Clock zone label",
      "default": "PST"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_press_url",
      "label": "Press link URL"
    },
    {
      "type": "text",
      "id": "social_press_label",
      "label": "Press link label",
      "default": "Press"
    }
  ]
}
{% endschema %}
