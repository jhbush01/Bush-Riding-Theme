{%- comment -%}
  Technical specs row — comfortably technical, per the brand voice: the
  details are here for those who want them, framed simply, never leading.

  Reads four product metafields and renders whichever exist as an icon +
  small-caps-label + value grid. If none are set, the section renders
  nothing at all. Define the metafields in Admin → Settings → Custom data →
  Products:
    specs.fabric_tech        (single line text)
    specs.weight_gsm         (integer)
    specs.riding_conditions  (single line text)
    specs.care_guide         (single line text)
{%- endcomment -%}

{%- liquid
  assign fabric = product.metafields.specs.fabric_tech.value
  assign weight = product.metafields.specs.weight_gsm.value
  assign conditions = product.metafields.specs.riding_conditions.value
  assign care = product.metafields.specs.care_guide.value
-%}

{%- if fabric != blank or weight != blank or conditions != blank or care != blank -%}
<div class="product-specs">
  {%- if section.settings.title != blank -%}
    <h2 class="product-specs__title">{{ section.settings.title | escape }}</h2>
  {%- endif -%}

  <div class="product-specs__grid">
    {%- if fabric != blank -%}
      <div class="product-specs__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l9 5-9 5-9-5 9-5zM3 13l9 5 9-5"/></svg>
        <span class="product-specs__label">Fabric</span>
        <span class="product-specs__value">{{ fabric }}</span>
      </div>
    {%- endif -%}
    {%- if weight != blank -%}
      <div class="product-specs__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.5 9.5c-3.5-4-10-4.5-14 0M12 3c-2 5 0 12 5 18M12 3c-4.5 4-6 12-2 18"/></svg>
        <span class="product-specs__label">Weight</span>
        <span class="product-specs__value">{{ weight }} gsm</span>
      </div>
    {%- endif -%}
    {%- if conditions != blank -%}
      <div class="product-specs__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="9" r="3.5"/><path d="M9 2.5v1.5M9 14v1.5M2.5 9H4M14 9h1.5M4.4 4.4l1 1M13.6 4.4l-1 1M22 17.5h-9M20 21h-7"/></svg>
        <span class="product-specs__label">Best for</span>
        <span class="product-specs__value">{{ conditions }}</span>
      </div>
    {%- endif -%}
    {%- if care != blank -%}
      <div class="product-specs__item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3s6.5 7 6.5 11.5a6.5 6.5 0 1 1-13 0C5.5 10 12 3 12 3z"/></svg>
        <span class="product-specs__label">Care</span>
        <span class="product-specs__value">{{ care }}</span>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .product-specs {
    max-width: 1100px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 48px) clamp(16px, 4vw, 48px);
  }

  .product-specs__title {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(22, 21, 15, 0.6);
    margin: 0 0 20px;
  }

  .product-specs__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
  }

  .product-specs__item {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 16px;
    border: 1px solid rgba(22, 21, 15, 0.12);
    border-radius: 3px;
  }

  .product-specs__item svg { width: 20px; height: 20px; color: rgba(22, 21, 15, 0.7); }

  .product-specs__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(22, 21, 15, 0.55);
  }

  .product-specs__value { font-size: 0.95rem; color: rgba(22, 21, 15, 0.9); }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Product specs",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The details"
    },
    {
      "type": "paragraph",
      "content": "Reads product metafields specs.fabric_tech, specs.weight_gsm, specs.riding_conditions and specs.care_guide. Renders nothing until at least one is set on the product."
    }
  ],
  "presets": [
    { "name": "Product specs" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
