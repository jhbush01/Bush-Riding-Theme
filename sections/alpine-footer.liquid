{%- comment -%}
  ALP1NE footer — newsletter ("Dispatches"), link columns, small print and the
  oversized wordmark bleeding off the bottom of the page. The newsletter uses
  Shopify's native customer form, so signups land in Admin → Customers with
  the accepts-marketing flag, tagged "newsletter".
{%- endcomment -%}

<footer class="alp alp-foot">
  <div class="alp-foot__dispatch" id="dispatches">
    <h2>{{ section.settings.newsletter_heading | escape }}</h2>
    <p>{{ section.settings.newsletter_text | escape }}</p>
    {%- form 'customer', class: 'alp-foot__form-wrap' -%}
      {%- if form.posted_successfully? -%}
        <p class="alp-foot__note" role="status">Thanks — you're on the list.</p>
      {%- else -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="alp-foot__form">
          <label class="visually-hidden" for="AlpDispatchEmail">Email address</label>
          <input
            id="AlpDispatchEmail"
            type="email"
            name="contact[email]"
            placeholder="Email address"
            autocomplete="email"
            required
          >
          <button class="alp-chip alp-chip--submit" type="submit">Subscribe</button>
        </div>
        {%- if form.errors -%}
          <p class="alp-foot__note" role="alert">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="alp-foot__columns">
      {%- for block in section.blocks -%}
        <nav aria-label="{{ block.settings.heading | escape }}" {{ block.shopify_attributes }}>
          <h3>{{ block.settings.heading | escape }}</h3>
          <ul role="list">
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <p class="alp-foot__small">© {{ section.settings.wordmark | default: shop.name | escape }} {{ 'now' | date: '%Y' }}{% if section.settings.small_print != blank %} — {{ section.settings.small_print | escape }}{% endif %}</p>

  <div class="alp-foot__wordmark" aria-hidden="true">{{ section.settings.wordmark | default: shop.name | escape }}</div>
</footer>

{% schema %}
{
  "name": "ALP1NE footer",
  "tag": "div",
  "settings": [
    { "type": "text", "id": "newsletter_heading", "label": "Newsletter heading", "default": "Dispatches" },
    { "type": "text", "id": "newsletter_text", "label": "Newsletter text", "default": "One email a month from the upper air. No noise." },
    { "type": "text", "id": "wordmark", "label": "Wordmark", "default": "ALP1NE™", "info": "Leave blank to use the store name." },
    { "type": "text", "id": "small_print", "label": "Small print" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
