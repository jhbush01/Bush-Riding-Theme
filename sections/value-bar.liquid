{%- comment -%}
  Value bar — a thin strip of three-or-four reassurances (shipping, returns,
  made-with-purpose) that quietly answers the questions people abandon carts
  over. Block-based so each item's icon, text and optional link are editable
  in the theme editor. Add it below the product info or under the home hero.
{%- endcomment -%}

{%- if section.blocks.size > 0 -%}
<div class="value-bar" role="list">
  {%- for block in section.blocks -%}
    {%- capture icon -%}
      {%- case block.settings.icon -%}
        {%- when 'shipping' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 6h13v10H1zM14 9h4l4 4v3h-8zM6 19.5a1.8 1.8 0 1 0 0-3.6 1.8 1.8 0 0 0 0 3.6zM18 19.5a1.8 1.8 0 1 0 0-3.6 1.8 1.8 0 0 0 0 3.6z"/></svg>
        {%- when 'returns' -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l4-4M3 9l4 4M3 9h12a6 6 0 1 1 0 12h-4"/></svg>
        {%- when 'star' -%}
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.9 6.4 3.7 9.1 10 10-6.3.9-9.1 3.6-10 10-.9-6.4-3.7-9.1-10-10 6.3-.9 9.1-3.6 10-10z"/></svg>
        {%- else -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v18M5 10c2.5 1.5 4.8 1.5 7 0 2.2 1.5 4.5 1.5 7 0M5 16c2.5 1.5 4.8 1.5 7 0 2.2 1.5 4.5 1.5 7 0"/></svg>
      {%- endcase -%}
    {%- endcapture -%}

    <div class="value-bar__item" role="listitem" {{ block.shopify_attributes }}>
      {%- if block.settings.link != blank -%}
        <a class="value-bar__inner" href="{{ block.settings.link }}">{{ icon }}<span>{{ block.settings.text | escape }}</span></a>
      {%- else -%}
        <span class="value-bar__inner">{{ icon }}<span>{{ block.settings.text | escape }}</span></span>
      {%- endif -%}
    </div>
  {%- endfor -%}
</div>

<style>
  .value-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px clamp(20px, 5vw, 64px);
    padding: 14px clamp(16px, 4vw, 48px);
    border-top: 1px solid rgba(22, 21, 15, 0.1);
    border-bottom: 1px solid rgba(22, 21, 15, 0.1);
  }

  .value-bar__inner {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(22, 21, 15, 0.75);
    text-decoration: none;
  }

  a.value-bar__inner:hover { color: rgba(22, 21, 15, 1); }

  .value-bar__inner svg { width: 18px; height: 18px; flex-shrink: 0; }

  @media screen and (max-width: 749px) {
    .value-bar { flex-direction: column; align-items: center; gap: 10px; }
  }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Value bar",
  "tag": "section",
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shipping", "label": "Shipping" },
            { "value": "returns", "label": "Returns" },
            { "value": "star", "label": "Star" },
            { "value": "plant", "label": "Plant" }
          ],
          "default": "shipping"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "Free shipping over $150" },
        { "type": "url", "id": "link", "label": "Link (optional)" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Value bar",
      "blocks": [
        { "type": "item", "settings": { "icon": "shipping", "text": "Free shipping over $150" } },
        { "type": "item", "settings": { "icon": "returns", "text": "30-day returns, no drama" } },
        { "type": "item", "settings": { "icon": "star", "text": "Designed in Australia" } }
      ]
    }
  ]
}
{% endschema %}
