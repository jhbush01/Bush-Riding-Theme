{%- comment -%}
  ─── TUNABLE CONSTANTS ───────────────────────────────────────────────────────
  KLAVIYO_PUBLIC_KEY  Your 6-character Klaviyo public/company API key
  KLAVIYO_LIST_ID     The Klaviyo list ID to subscribe new emails to
  ─────────────────────────────────────────────────────────────────────────────
{%- endcomment -%}

<style>
  /* ── Design tokens ── swap these to restyle the whole page */
  :root {
    --text-color:   #F5F0E6;          /* cream wordmark + input placeholder */
    --bush-lemon:   #C9CB52;          /* submit button fill + hairline rule  */
    --scrim:        0.4;              /* dark overlay opacity (0–1)          */
    --box-padding:  clamp(20px, 6vw, 50px);   /* logo box padding           */
    --box-max-width: 520px;           /* max width of the logo box           */
    --form-max-width: 420px;          /* max width of the email row          */
    --bg-image: url('{{ 'bush-mountain.jpg' | asset_url }}');  /* swap asset here */
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.waitlist {
    min-height: 100dvh;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    padding: 40px 20px 60px;
  }

  /* ── Box logo ─────────────────────────────────────────────────────────────── */
  .waitlist-logo {
    position: relative;
    width: 100%;
    max-width: var(--box-max-width);
    overflow: hidden;
    /* height driven by padding-top trick for square-ish proportions */
    aspect-ratio: 1 / 1;
  }

  .waitlist-logo__bg {
    position: absolute;
    inset: 0;
    background-image: var(--bg-image);
    background-size: cover;
    background-position: center;
  }

  .waitlist-logo__scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, var(--scrim));
  }

  .waitlist-logo__inner {
    position: relative;      /* above bg + scrim */
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--box-padding);
    gap: 0;
  }

  .waitlist-logo__wordmark {
    font-family: "Times New Roman", Times, serif;
    font-size: clamp(2rem, 8vw, 4.5rem);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1;
    color: var(--text-color);
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
    text-align: center;
    white-space: nowrap;
  }

  .waitlist-logo__rule {
    width: 100%;
    height: 1px;
    background: var(--bush-lemon);
    margin-top: 12px;
    flex-shrink: 0;
  }

  /* ── Email capture ─────────────────────────────────────────────────────────── */
  .waitlist-form-wrap {
    margin-top: 40px;
    width: 100%;
    max-width: var(--form-max-width);
  }

  .waitlist-form {
    display: flex;
    border: 1px solid #d0d0d0;
    border-radius: 9999px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .waitlist-form__input {
    flex: 1;
    border: none;
    outline: none;
    padding: 14px 20px;
    font-size: 0.95rem;
    background: transparent;
    color: #111;
  }

  .waitlist-form__input::placeholder { color: #999; }

  .waitlist-form__submit {
    flex-shrink: 0;
    border: none;
    outline: none;
    cursor: pointer;
    background: var(--bush-lemon);
    color: #1a1a00;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 14px 24px;
    border-radius: 0 9999px 9999px 0;
    transition: filter 0.15s ease;
  }

  .waitlist-form__submit:hover { filter: brightness(1.08); }

  /* ── Status messages ─────────────────────────────────────────────────────── */
  .waitlist-status {
    margin-top: 14px;
    font-size: 0.875rem;
    text-align: center;
    min-height: 1.2em;
    color: #444;
  }

  .waitlist-status--error { color: #c0392b; }
  .waitlist-status--success { color: #2d6a2d; }
</style>

<div class="waitlist-logo" role="img" aria-label="{{ shop.name }}">
  <div class="waitlist-logo__bg" aria-hidden="true"></div>
  <div class="waitlist-logo__scrim" aria-hidden="true"></div>
  <div class="waitlist-logo__inner">
    <span class="waitlist-logo__wordmark">Bush Riding</span>
    <div class="waitlist-logo__rule" aria-hidden="true"></div>
  </div>
</div>

<div class="waitlist-form-wrap">
  <form class="waitlist-form" id="waitlist-form" novalidate>
    <input
      class="waitlist-form__input"
      type="email"
      name="email"
      id="waitlist-email"
      placeholder="your@email.com"
      autocomplete="email"
      required
    >
    <button class="waitlist-form__submit" type="submit">Notify me</button>
  </form>
  <p class="waitlist-status" id="waitlist-status" role="status" aria-live="polite"></p>
</div>

<script>
  (function () {
    // ── Klaviyo config ── replace these two values ──────────────────────────
    var KLAVIYO_PUBLIC_KEY = 'REPLACE_ME';   // e.g. 'AbCdEf'
    var KLAVIYO_LIST_ID    = 'REPLACE_ME';   // e.g. 'XyZ123'
    // ────────────────────────────────────────────────────────────────────────

    var form   = document.getElementById('waitlist-form');
    var status = document.getElementById('waitlist-status');

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var email = document.getElementById('waitlist-email').value.trim();

      if (!email) {
        showStatus('Please enter your email address.', 'error');
        return;
      }

      var btn = form.querySelector('.waitlist-form__submit');
      btn.disabled = true;
      showStatus('', '');

      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'revision': '2024-10-15'
        },
        body: JSON.stringify({
          data: {
            type: 'subscription',
            attributes: {
              profile: {
                data: {
                  type: 'profile',
                  attributes: { email: email }
                }
              }
            },
            relationships: {
              list: {
                data: { type: 'list', id: KLAVIYO_LIST_ID }
              }
            }
          }
        })
      })
      .then(function (res) {
        if (res.status === 202) {
          showStatus("You're on the list — we'll be in touch.", 'success');
          form.reset();
        } else {
          return res.json().then(function (body) {
            throw new Error((body.errors && body.errors[0] && body.errors[0].detail) || 'Something went wrong.');
          });
        }
      })
      .catch(function (err) {
        showStatus(err.message || 'Something went wrong. Please try again.', 'error');
      })
      .finally(function () {
        btn.disabled = false;
      });
    });

    function showStatus(msg, type) {
      status.textContent = msg;
      status.className = 'waitlist-status' + (type ? ' waitlist-status--' + type : '');
    }
  })();
</script>

{% schema %}
{
  "name": "Waitlist",
  "tag": "section",
  "class": "waitlist-section"
}
{% endschema %}
