<style>
  /* ── Design tokens ─────────────────────────────────────────────────────── */
  :root {
    --ivory:       #F5F0E8;
    --lemon:       #F9C80E;
    --btn-text:    #2A2318;
    --overlay:     rgba(0, 0, 0, 0.05);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.waitlist {
    background: #F5F0E8;
    font-family: 'General Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    height: 100dvh;
    overflow: hidden;
  }

  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .wl-hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F5F0E8;
    overflow: hidden;
  }

  /* ── Video ─────────────────────────────────────────────────────────────── */
  .wl-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .wl-overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay);
    z-index: 1;
  }

  /* ── Content stack ─────────────────────────────────────────────────────── */
  .wl-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 24px;
    width: 100%;
    max-width: 700px;
  }

  .wl-content form {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* ── Brand mark ────────────────────────────────────────────────────────── */
  .wl-brand-mark {
    max-height: 140px;
    width: auto;
    display: block;
    margin-bottom: 28px;
    animation: wl-fade-in 2.8s ease-out both;
  }

  @media (max-width: 767px) {
    .wl-brand-mark { max-height: 90px; }
  }

  /* ── Headline ──────────────────────────────────────────────────────────── */
  .wl-headline {
    display: block;
    font-family: 'Instrument Serif', serif;
    font-size: clamp(56px, 8vw, 96px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--lemon);
    animation: wl-fade-in 2.8s ease-out both;
  }

  @keyframes wl-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wl-headline { animation: none; }
  }

  .wl-rule { display: none; }

  /* ── Subhead ───────────────────────────────────────────────────────────── */
  .wl-subhead {
    font-family: 'General Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--ivory);
    opacity: 0.85;
    white-space: nowrap;
    margin-bottom: 32px;
    text-shadow: 0 1px 6px rgba(0,0,0,0.55), 0 0 20px rgba(0,0,0,0.4);
  }

  /* ── Email form ────────────────────────────────────────────────────────── */
  .wl-form {
    display: flex;
    gap: 10px;
    width: 100%;
    max-width: 480px;
    margin-bottom: 14px;
  }

  .wl-form__input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 1px solid var(--ivory);
    border-radius: 9999px;
    padding: 13px 20px;
    font-family: 'General Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--ivory);
    outline: none;
    transition: border-color 0.15s;
  }

  .wl-form__input::placeholder { color: rgba(245, 240, 232, 0.55); }
  .wl-form__input:focus { border-color: var(--lemon); }

  .wl-form__submit {
    flex-shrink: 0;
    border: none;
    outline: none;
    cursor: pointer;
    background: var(--lemon);
    color: var(--btn-text);
    font-family: 'General Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 13px 22px;
    border-radius: 9999px;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  .wl-form__submit:hover { opacity: 0.88; }
  .wl-form__submit:disabled { opacity: 0.55; cursor: not-allowed; }

  /* ── Microcopy ─────────────────────────────────────────────────────────── */
  .wl-micro {
    font-family: 'General Sans', sans-serif;
    font-size: 0.72rem;
    color: var(--ivory);
    opacity: 0.85;
    text-shadow: 0 1px 6px rgba(0,0,0,0.55), 0 0 20px rgba(0,0,0,0.4);
  }

  /* ── Status ────────────────────────────────────────────────────────────── */
  .wl-status {
    margin-top: 12px;
    font-family: 'General Sans', sans-serif;
    font-size: 0.85rem;
    color: var(--ivory);
    min-height: 1.2em;
  }

  .wl-status--error   { color: #ffb3ae; }
  .wl-status--success { color: #b9f6ca; }

  .wl-success-msg {
    font-family: 'General Sans', sans-serif;
    font-size: 1rem;
    color: var(--ivory);
    text-shadow: 0 1px 6px rgba(0,0,0,0.55);
    opacity: 0.75;
  }

  /* ── Mobile ────────────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .wl-headline { font-size: clamp(40px, 11vw, 56px); }

    .wl-subhead { white-space: normal; }

    .wl-form {
      flex-direction: column;
      gap: 10px;
    }

    .wl-form__input,
    .wl-form__submit {
      width: 100%;
    }
  }
</style>

<section class="wl-hero">
  <video class="wl-video" autoplay muted loop playsinline aria-hidden="true">
    <source src="https://cdn.shopify.com/videos/c/o/v/f0e0ccc583fc45589dc4a168fc145f35.mp4" type="video/mp4">
  </video>
  <div class="wl-overlay" aria-hidden="true"></div>

  <div class="wl-content">
    {%- form 'customer', id: 'WaitlistForm' -%}
      {%- if form.posted_successfully? -%}

        <p class="wl-success-msg">You're on the list — we will send you launch updates, ride stories and first access.</p>

      {%- else -%}

        <img
          class="wl-brand-mark"
          src="https://cdn.shopify.com/s/files/1/0838/6373/2480/files/IMG_0671-removebg-preview.png?v=1782476546"
          alt="Bush Riding"
        >
        <div class="wl-headline-wrap">
          <span class="wl-headline">Welcome to the Bush</span>
        </div>
        <p class="wl-subhead" style="margin-top:20px;">Early access to Bush Riding's first release.</p>

        <input type="hidden" name="contact[tags]" value="waitlist">
        <div class="wl-form">
          <input
            class="wl-form__input"
            type="email"
            name="contact[email]"
            id="waitlist-email"
            placeholder="your@email.com"
            autocomplete="email"
            required
          >
          <button class="wl-form__submit" type="submit">Join early access</button>
        </div>
        {%- if form.errors -%}
          <p class="wl-status wl-status--error">
            {%- if form.errors contains 'email' -%}
              Please enter a valid email address.
            {%- else -%}
              Something went wrong. Please try again.
            {%- endif -%}
          </p>
        {%- endif -%}

        <p class="wl-micro">Join for launch updates, ride stories, and first access.</p>

      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Waitlist",
  "tag": "section",
  "class": "waitlist-section"
}
{% endschema %}
