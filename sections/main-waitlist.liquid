<style>
  /* ── Design tokens ─────────────────────────────────────────────────────── */
  :root {
    --ivory:       #F5F0E8;
    --lemon:       #C9C81A;
    --btn-text:    #2A2318;
    --overlay:     rgba(0, 0, 0, 0.25);
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body.waitlist {
    background: #F5F0E8;
    font-family: 'General Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    height: 100dvh;
    overflow: hidden;
  }

  /* ── Hero ──────────────────────────────────────────────────────────────── */
  .wl-hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #F5F0E8;
    overflow: hidden;
  }

  /* ── Video ─────────────────────────────────────────────────────────────── */
  .wl-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .wl-overlay {
    position: absolute;
    inset: 0;
    background: var(--overlay);
    z-index: 1;
  }

  /* ── Content stack ─────────────────────────────────────────────────────── */
  .wl-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0 24px;
    width: 100%;
    max-width: 700px;
  }

  /* ── Logo ──────────────────────────────────────────────────────────────── */
  .wl-logo {
    font-family: 'General Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ivory);
    opacity: 0.8;
    margin-bottom: 36px;
  }

  .wl-logo-img {
    max-height: 28px;
    width: auto;
    display: block;
    margin-bottom: 36px;
    opacity: 0.9;
  }

  /* ── Headline ──────────────────────────────────────────────────────────── */
  .wl-headline-wrap {
    overflow: hidden;
  }

  .wl-headline {
    display: block;
    font-family: 'Instrument Serif', serif;
    font-size: clamp(56px, 8vw, 96px);
    font-weight: 400;
    line-height: 1.05;
    color: var(--ivory);
    animation: wl-slide-up 0.8s ease-out both;
  }

  @keyframes wl-slide-up {
    from { transform: translateY(110%); }
    to   { transform: translateY(0);    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wl-headline { animation: none; }
  }

  /* ── Lemon underline ───────────────────────────────────────────────────── */
  .wl-rule {
    width: 100%;
    height: 1.5px;
    background: var(--lemon);
    margin: 10px 0 28px;
    flex-shrink: 0;
  }

  /* ── Subhead ───────────────────────────────────────────────────────────── */
  .wl-subhead {
    font-family: 'General Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--ivory);
    opacity: 0.75;
    white-space: nowrap;
    margin-bottom: 32px;
  }

  /* ── Email form ────────────────────────────────────────────────────────── */
  .wl-form {
    display: flex;
    gap: 10px;
    width: 100%;
    max-width: 480px;
    margin-bottom: 14px;
  }

  .wl-form__input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 1px solid var(--ivory);
    border-radius: 9999px;
    padding: 13px 20px;
    font-family: 'General Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--ivory);
    outline: none;
    transition: border-color 0.15s;
  }

  .wl-form__input::placeholder { color: rgba(245, 240, 232, 0.55); }
  .wl-form__input:focus { border-color: var(--lemon); }

  .wl-form__submit {
    flex-shrink: 0;
    border: none;
    outline: none;
    cursor: pointer;
    background: var(--lemon);
    color: var(--btn-text);
    font-family: 'General Sans', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 13px 22px;
    border-radius: 9999px;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  .wl-form__submit:hover { opacity: 0.88; }
  .wl-form__submit:disabled { opacity: 0.55; cursor: not-allowed; }

  /* ── Microcopy ─────────────────────────────────────────────────────────── */
  .wl-micro {
    font-family: 'General Sans', sans-serif;
    font-size: 0.72rem;
    color: var(--ivory);
    opacity: 0.6;
  }

  /* ── Status ────────────────────────────────────────────────────────────── */
  .wl-status {
    margin-top: 12px;
    font-family: 'General Sans', sans-serif;
    font-size: 0.85rem;
    color: var(--ivory);
    min-height: 1.2em;
  }

  .wl-status--error   { color: #ffb3ae; }
  .wl-status--success { color: #b9f6ca; }

  /* ── Mobile ────────────────────────────────────────────────────────────── */
  @media (max-width: 767px) {
    .wl-headline { font-size: clamp(40px, 11vw, 56px); }

    .wl-subhead { white-space: normal; }

    .wl-form {
      flex-direction: column;
      gap: 10px;
    }

    .wl-form__input,
    .wl-form__submit {
      width: 100%;
    }
  }
</style>

<section class="wl-hero">
  <video class="wl-video" autoplay muted loop playsinline aria-hidden="true">
    <source src="https://cdn.shopify.com/videos/c/o/v/a28565397d6b4a7d878537dd052bd970.mp4" type="video/mp4">
  </video>
  <div class="wl-overlay" aria-hidden="true"></div>

  <div class="wl-content">

    {%- if settings.logo != blank -%}
      {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
      {{
        settings.logo
        | image_url: width: 200
        | image_tag:
          class: 'wl-logo-img',
          width: 100,
          alt: logo_alt
      }}
    {%- else -%}
      <p class="wl-logo">{{ shop.name }}</p>
    {%- endif -%}

    <div class="wl-headline-wrap">
      <span class="wl-headline">Welcome to the Bush</span>
    </div>
    <div class="wl-rule" aria-hidden="true"></div>

    <p class="wl-subhead">Early access to Bush Riding's first release.</p>

    <form class="wl-form" id="waitlist-form" novalidate>
      <input
        class="wl-form__input"
        type="email"
        name="email"
        id="waitlist-email"
        placeholder="your@email.com"
        autocomplete="email"
        required
      >
      <button class="wl-form__submit" type="submit">Join early access</button>
    </form>

    <p class="wl-micro">Join for launch updates, ride stories, and first access.</p>
    <p class="wl-status" id="waitlist-status" role="status" aria-live="polite"></p>

  </div>
</section>

<script>
  (function () {
    // ── Klaviyo config ── replace these two values ───────────────────────────
    var KLAVIYO_PUBLIC_KEY = 'W9QAij';
    var KLAVIYO_LIST_ID    = 'RgzXQa';
    // ─────────────────────────────────────────────────────────────────────────

    var form   = document.getElementById('waitlist-form');
    var status = document.getElementById('waitlist-status');

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var email = document.getElementById('waitlist-email').value.trim();
      if (!email) { showStatus('Please enter your email address.', 'error'); return; }

      var btn = form.querySelector('.wl-form__submit');
      btn.disabled = true;
      showStatus('', '');

      fetch('https://a.klaviyo.com/client/subscriptions/?company_id=' + KLAVIYO_PUBLIC_KEY, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'revision': '2024-10-15' },
        body: JSON.stringify({
          data: {
            type: 'subscription',
            attributes: {
              profile: { data: { type: 'profile', attributes: { email: email } } }
            },
            relationships: { list: { data: { type: 'list', id: KLAVIYO_LIST_ID } } }
          }
        })
      })
      .then(function (res) {
        if (res.status === 202) {
          showStatus("You're on the list — we'll be in touch.", 'success');
          form.reset();
        } else {
          return res.json().then(function (body) {
            throw new Error((body.errors && body.errors[0] && body.errors[0].detail) || 'Something went wrong.');
          });
        }
      })
      .catch(function (err) {
        showStatus(err.message || 'Something went wrong. Please try again.', 'error');
      })
      .finally(function () { btn.disabled = false; });
    });

    function showStatus(msg, type) {
      status.textContent = msg;
      status.className = 'wl-status' + (type ? ' wl-status--' + type : '');
    }
  })();
</script>

{% schema %}
{
  "name": "Waitlist",
  "tag": "section",
  "class": "waitlist-section"
}
{% endschema %}
